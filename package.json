{
  "name": "enterprise-platform",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.6.5",
  "scripts": {
    "dev": "nx run dashboard-web:dev",
    "build": "nx run dashboard-web:build",
    "start": "nx run dashboard-web:start",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "typecheck": "tsc -p tsconfig.base.json --noEmit",
    "api:dev": "nx run api:dev",
    "api:build": "nx run api:build",
    "api:start": "nx run api:start",
    "api:generate": "dotenv -e apps/api/.env -- pnpm exec prisma generate --schema apps/api/src/prisma/schema.prisma",
    "prisma:generate": "dotenv -e apps/api/.env -- prisma generate --schema apps/api/src/prisma/schema.prisma",
    "prisma:migrate": "dotenv -e apps/api/.env -- prisma migrate dev --schema apps/api/src/prisma/schema.prisma",
    "prisma:seed": "tsx --env-file apps/api/.env apps/api/src/prisma/seed.ts",
    "prisma:studio": "dotenv -e apps/api/.env -- prisma studio --schema apps/api/src/prisma/schema.prisma",
    "codegen": "graphql-codegen --config codegen.ts",
    "codegen:watch": "graphql-codegen --config codegen.ts --watch"
  },
  "dependencies": {
    "@apollo/server": "^5.4.0",
    "@as-integrations/express5": "^1.1.2",
    "@casl/ability": "^6.8.0",
    "@casl/react": "^5.0.1",
    "@graphql-typed-document-node/core": "^3.2.0",
    "@nestjs/apollo": "^13.2.1",
    "@nestjs/common": "^11.1.6",
    "@nestjs/core": "^11.1.6",
    "@nestjs/graphql": "^13.2.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.6",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^6.4.1",
    "@szhsin/react-menu": "^4.5.1",
    "@tanstack/react-form": "^1.28.4",
    "@tanstack/react-table": "^8.21.3",
    "axios": "^1.8.4",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dataloader": "^2.2.3",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "framer-motion": "^12.35.0",
    "graphql": "^16.10.0",
    "graphql-type-json": "^0.3.2",
    "lucide-react": "^0.511.0",
    "next": "^15.2.0",
    "next-auth": "5.0.0-beta.30",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "react": "^19.0.0",
    "react-date-picker": "^12.0.1",
    "react-daterange-picker": "^2.0.1",
    "react-dom": "^19.0.0",
    "react-paginate": "^8.3.0",
    "react-select": "^5.10.2",
    "react-tabs": "^6.1.0",
    "react-time-picker": "^8.0.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.0",
    "zod": "^4.3.6"
  },
  "prisma": {
    "seed": "tsx --env-file apps/api/.env apps/api/src/prisma/seed.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@graphql-codegen/cli": "^6.2.1",
    "@graphql-codegen/client-preset": "^5.2.4",
    "@nx/js": "22.5.4",
    "@nx/next": "22.5.4",
    "@nx/workspace": "22.5.4",
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.21",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^22.13.10",
    "@types/passport-jwt": "^4.0.1",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "autoprefixer": "^10.4.20",
    "dotenv-cli": "^11.0.0",
    "nx": "22.5.4",
    "postcss": "^8.5.3",
    "prisma": "^6.4.1",
    "prisma-nestjs-graphql": "^21.2.0",
    "tailwindcss": "^3.4.17",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.20.5",
    "typescript": "^5.8.2"
  }
}
