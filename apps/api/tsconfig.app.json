{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@api/*": ["src/*"],
      "@/*": ["src/*"]
    },
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "es2021",
    "outDir": "../../dist/apps/api",
    "rootDir": "./src",
    "declaration": false,
    "sourceMap": true,
    "noEmit": false,
    "types": ["node"],
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strictPropertyInitialization": false
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/**/*.spec.ts"]
}
