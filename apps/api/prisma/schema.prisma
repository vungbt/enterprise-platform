generator client {
  provider = "prisma-client-js"
}

generator nestgraphql {
  provider = "node node_modules/prisma-nestjs-graphql"
  output   = "../src/prisma/graphql"
  purgeOutput = true
  reExport = Single
  noAtomicOperations = true
  tsConfigFilePath = "apps/api/tsconfig.app.json"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// AUTH & RBAC
// ============================================================

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String
  /// @HideField({ input: true, output: true })
  password  String
  avatar    String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  roles                  UserRole[]
  employees              Employee[]
  ownedCustomers         Customer[]         @relation("CustomerOwner")
  clubMemberships        ClubMember[]
  ownedClubs             Club[]             @relation("ClubOwner")
  expenses               Expense[]
  confirmedContributions FundContribution[] @relation("FundContributionConfirmer")
  fundTransactions       FundTransaction[]  @relation("FundTransactionCreator")

  @@map("users")
}

model Role {
  id    String @id @default(cuid())
  name  String @unique // "hr_manager", "finance_viewer", "admin"
  label String // "HR Manager", "Finance Viewer", "Admin"

  permissions RolePermission[]
  users       UserRole[]

  @@map("roles")
}

model RolePermission {
  roleId     String
  permission String // "view:hr", "create:hr", "delete:finance", ...

  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permission])
  @@map("role_permissions")
}

model UserRole {
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

// ============================================================
// HR
// ============================================================

enum EmployeeStatus {
  active
  resigned
  terminated
  on_leave
}

model Department {
  id       String  @id @default(cuid())
  name     String  @unique
  parentId String?

  parent    Department?  @relation("DepartmentTree", fields: [parentId], references: [id])
  children  Department[] @relation("DepartmentTree")
  employees Employee[]
  expenses  Expense[]

  @@map("departments")
}

model Employee {
  id           String         @id @default(cuid())
  code         String         @unique // "EMP-001"
  name         String
  email        String         @unique
  phone        String?
  position     String
  hireDate     DateTime
  status       EmployeeStatus @default(active)
  departmentId String
  managerId    String?
  userId       String? // link to User account (optional)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  department Department  @relation(fields: [departmentId], references: [id])
  manager    Employee?   @relation("EmployeeManager", fields: [managerId], references: [id])
  reports    Employee[]  @relation("EmployeeManager")
  user       User?       @relation(fields: [userId], references: [id])

  @@map("employees")
}

// ============================================================
// CRM
// ============================================================

enum CustomerStatus {
  prospect
  active
  inactive
  churned
}

model Customer {
  id        String         @id @default(cuid())
  name      String
  email     String?
  phone     String?
  company   String?
  status    CustomerStatus @default(prospect)
  ownerId   String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  owner    User      @relation("CustomerOwner", fields: [ownerId], references: [id])
  invoices Invoice[]

  @@map("customers")
}

// ============================================================
// FINANCE
// ============================================================

enum InvoiceStatus {
  draft
  pending
  paid
  overdue
  cancelled
}

model Invoice {
  id         String        @id @default(cuid())
  code       String        @unique // "INV-2024-001"
  amount     Float
  tax        Float         @default(0)
  total      Float
  status     InvoiceStatus @default(draft)
  dueDate    DateTime?
  issuedAt   DateTime?
  customerId String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  customer Customer? @relation(fields: [customerId], references: [id])

  @@map("invoices")
}

// ============================================================
// INVENTORY
// ============================================================

enum InventoryItemStatus {
  available
  low_stock
  out_of_stock
  discontinued
}

model InventoryItem {
  id        String              @id @default(cuid())
  sku       String              @unique
  name      String
  category  String?
  stock     Int                 @default(0)
  minStock  Int                 @default(0)
  unit      String              @default("pcs")
  price     Float               @default(0)
  status    InventoryItemStatus @default(available)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@map("inventory_items")
}

// ============================================================
// SPORTS & CLUBS
// ============================================================

enum ClubStatus {
  active
  inactive
}

enum ClubMemberRole {
  captain
  coach
  member
}

enum ClubMemberStatus {
  active
  left
  banned
}

model Club {
  id          String     @id @default(cuid())
  name        String
  sport       String
  description String?
  status      ClubStatus @default(active)
  foundedAt   DateTime?
  createdById String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?

  createdBy User         @relation("ClubOwner", fields: [createdById], references: [id])
  members   ClubMember[]
  expenses  Expense[]
  fund      ClubFund?

  @@map("clubs")
}

// Thành viên CLB trong hệ thống: luôn gắn một User đã đăng ký (một user — tối đa một membership / club).
model ClubMember {
  id          String   @id @default(cuid())
  clubId      String
  userId      String
  displayName String
  email       String?
  phone       String?
  note        String?
  role        ClubMemberRole   @default(member)
  status      ClubMemberStatus @default(active)
  joinedAt    DateTime         @default(now())
  leftAt      DateTime?

  club              Club               @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  fundContributions FundContribution[]

  @@unique([clubId, userId])
  @@index([clubId])
  @@map("club_members")
}

// Quy cau lac bo — moi CLB co toi da 1 quy
// Current balance = FundTransaction moi nhat cua quy.balanceAfter
// Khong bao gio tinh runtime bang SUM — lay tu ledger
model ClubFund {
  id             String    @id @default(cuid())
  clubId         String    @unique
  name           String    @default("Quy cau lac bo")
  initialBalance Float     @default(0) // opening balance khi tao quy
  description    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  club          Club               @relation(fields: [clubId], references: [id], onDelete: Cascade)
  contributions FundContribution[]
  expenses      Expense[]
  transactions  FundTransaction[]

  @@map("club_funds")
}

// ─── So cai (Ledger) ───────────────────────────────────────
// Moi bien dong tien (thu / chi / dieu chinh / hoan) tao 1 dong.
// balanceAfter = snapshot so du SAU khi ap dung transaction nay.
// rollback = tao 1 transaction dao chieu (reversal), khong sua dong cu.
// Race condition: service phai dung DB transaction + SELECT FOR UPDATE
// truoc khi tinh balanceAfter moi.

enum FundTransactionType {
  contribution // thu tien thanh vien
  expense // chi tien tu quy
  adjustment // dieu chinh thu cong (admin)
  refund // hoan tien
}

// flow xac dinh chieu tang/giam ro rang, tranh implicit logic
enum FundFlow {
  inflow // tien vao quy (+)
  outflow // tien ra khoi quy (-)
}

model FundTransaction {
  id               String              @id @default(cuid())
  fundId           String
  type             FundTransactionType
  flow             FundFlow // inflow = cong; outflow = tru
  amount           Float // luon duong; chieu xac dinh boi flow
  balanceAfter     Float // snapshot so du sau transaction nay
  note             String?
  refContribId     String? // neu type = contribution
  refExpenseId     String? // neu type = expense
  refTransactionId String? // neu la reversal cua 1 transaction khac
  createdById      String
  createdAt        DateTime @default(now())

  fund         ClubFund          @relation(fields: [fundId], references: [id])
  contribution FundContribution? @relation(fields: [refContribId], references: [id])
  expense      Expense?          @relation(fields: [refExpenseId], references: [id])
  createdBy    User              @relation("FundTransactionCreator", fields: [createdById], references: [id])

  @@index([fundId, createdAt])
  @@map("fund_transactions")
}

// ─── Thu tien thanh vien ────────────────────────────────────
// Khi status chuyen confirmed → service tao FundTransaction(type=contribution, flow=inflow)
// Service phai dung DB transaction + SELECT FOR UPDATE de tranh race condition.

enum FundContributionStatus {
  pending // cho xac nhan
  confirmed // da thu — da co FundTransaction tuong ung
  cancelled // huy
}

model FundContribution {
  id             String                 @id @default(cuid())
  fundId         String
  clubMemberId   String
  // month + year thay cho period String de tranh format sai va de query theo date range
  month          Int? // 1-12; null = dong gop 1 lan (khong theo ky)
  year           Int? // e.g. 2025
  amount         Float
  note           String?
  paidAt         DateTime
  status         FundContributionStatus @default(pending)
  confirmedBy    String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  fund            ClubFund   @relation(fields: [fundId], references: [id], onDelete: Cascade)
  clubMember      ClubMember @relation(fields: [clubMemberId], references: [id], onDelete: Cascade)
  confirmedByUser User?      @relation("FundContributionConfirmer", fields: [confirmedBy], references: [id])
  transactions    FundTransaction[]

  // Mot dong member trong CLB chi dong 1 lan moi ky (khi ca month va year deu co gia tri)
  @@unique([fundId, clubMemberId, month, year])
  @@map("fund_contributions")
}

// ============================================================
// EXPENSE MANAGEMENT
// ============================================================

enum ExpenseStatus {
  pending
  approved
  rejected
  reimbursed
}

model ExpenseCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  expenses Expense[]

  @@map("expense_categories")
}

model Expense {
  id           String        @id @default(cuid())
  title        String
  amount       Float
  description  String?
  date         DateTime
  status       ExpenseStatus @default(pending)
  categoryId   String
  createdById  String
  clubId       String?
  departmentId String?
  // fundId: khi set, service phai enforce clubId == fund.clubId
  fundId       String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?

  category         ExpenseCategory  @relation(fields: [categoryId], references: [id])
  createdBy        User             @relation(fields: [createdById], references: [id])
  club             Club?            @relation(fields: [clubId], references: [id])
  department       Department?      @relation(fields: [departmentId], references: [id])
  fund             ClubFund?        @relation(fields: [fundId], references: [id])
  fundTransactions FundTransaction[]

  @@index([clubId, fundId])
  @@map("expenses")
}
