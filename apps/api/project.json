{
  "name": "api",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/api/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/apps/api"],
      "options": {
        "cwd": "{workspaceRoot}",
        "parallel": false,
        "env": {
          "DATABASE_URL": "postgresql://u:p@localhost:5432/db"
        },
        "commands": [
          "pnpm exec prisma generate --schema apps/api/prisma/schema.prisma",
          "pnpm exec tsc --project apps/api/tsconfig.app.json",
          "pnpm exec tsc-alias -p apps/api/tsconfig.app.json",
          "mkdir -p dist/apps/api/prisma && cp apps/api/prisma/schema.prisma dist/apps/api/prisma/schema.prisma"
        ]
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{workspaceRoot}",
        "command": "DOTENV_CONFIG_PATH=apps/api/.env pnpm exec tsx --tsconfig apps/api/tsconfig.app.json apps/api/src/main.ts"
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{workspaceRoot}",
        "command": "node dist/apps/api/main.js"
      },
      "dependsOn": ["build"]
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "biome lint apps/api"
      }
    }
  },
  "tags": []
}
