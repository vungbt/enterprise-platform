{
  "name": "api",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/api/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/api",
        "main": "apps/api/src/main.ts",
        "tsConfig": "apps/api/tsconfig.app.json",
        "assets": ["apps/api/src/**/*.graphql", "apps/api/prisma/schema.prisma"]
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "DOTENV_CONFIG_PATH=apps/api/.env SWC_NODE_PROJECT=apps/api/tsconfig.app.json node --require dotenv/config --require @swc-node/register apps/api/src/main.ts"
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node dist/apps/api/main.js"
      },
      "dependsOn": ["build"]
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "biome lint apps/api"
      }
    }
  },
  "tags": []
}
